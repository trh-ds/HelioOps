# HelioOps Backend Configuration
# Copy this file to .env and fill in values

# ── Server ────────────────────────────────────────────
HELIOOPS_HOST=0.0.0.0
HELIOOPS_PORT=8000
HELIOOPS_WORKERS=1
HELIOOPS_RELOAD=true

# ── Logging ───────────────────────────────────────────
HELIOOPS_LOG_LEVEL=INFO
# Options: json, console
HELIOOPS_LOG_FORMAT=json

# ── LLM ───────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048

# ── ML ────────────────────────────────────────────────
HELIOOPS_ML_CHECKPOINT_DIR=ML_after_CV/checkpoints

# ── RAG ────────────────────────────────────────────────
HELIOOPS_CHROMA_PERSIST_PATH=data/chroma_db